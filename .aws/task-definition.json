{
    "family": "vowerp3ui-dev-task",
    "containerDefinitions": [
        {
            "name": "vowerp3ui-dev",
            "image": "782803702444.dkr.ecr.ap-south-1.amazonaws.com/my-next-app-dev:latest",
            "cpu": 512,
            "memory": 1536,
            "memoryReservation": 1024,
            "portMappings": [
                {
                    "name": "ui-dev",
                    "containerPort": 3000,
                    "hostPort": 3000,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [],
            "mountPoints": [],
            "volumesFrom": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/my-nextjs-task",
                    "mode": "non-blocking",
                    "awslogs-create-group": "true",
                    "max-buffer-size": "25m",
                    "awslogs-region": "ap-south-1",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "systemControls": []
        }
    ],
    "volumes": [],
    "placementConstraints": []
}